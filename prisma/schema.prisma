generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── MULTI-TENANT WORKSPACE ──────────────────────────────────────────────────

model Workspace {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  logoUrl     String?
  timezone    String    @default("UTC")
  plan        String    @default("free") // free, starter, pro, enterprise
  trialEndsAt DateTime?

  // NEW FIELDS
  defaultChannel         String  @default("whatsapp")
  aiReplyDelayEnabled    Boolean @default(true)
  businessHoursStart     String?
  businessHoursEnd       String?
  maxConcurrentAIReplies Int     @default(10)
  webhookSecret          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       WorkspaceMember[]
  leads         Lead[]
  followUps     FollowUp[]
  conversations Conversation[]
  agentConfigs  AgentConfig[]
  integrations  Integration[]
  subscriptions Subscription[]
  jobQueue      JobQueue[]
  webhookEvents WebhookEvent[]
  handoffs      HumanHandoff[]
  roiEvents     ROIEvent[]
  memoryEntries MemoryEntry[]
  aiDecisionLogs AIDecisionLog[]
  properties    Property[]
  appointments  Appointment[]
  notifications Notification[]
  whatsappMessages WhatsAppMessage[]
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String    @default("agent") // owner, admin, agent, viewer
  joinedAt    DateTime  @default(now())

  @@unique([workspaceId, userId])
}

// ─── USER ────────────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  name        String?
  email       String   @unique
  password    String
  agencyName  String?
  writingTone String   @default("professional") // professional, friendly, casual
  avatarUrl   String?
  phone       String?
  notifyEmail Boolean  @default(true)
  notifySMS   Boolean  @default(false)
  emailVerified        DateTime?
  verificationToken    String?   @unique
  resetPasswordToken   String?   @unique
  resetPasswordExpires DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaces WorkspaceMember[]
  leads      Lead[]
  handoffs   HumanHandoff[]
  notifications Notification[]
}

// ─── LEAD ────────────────────────────────────────────────────────────────────

model Lead {
  id                 String    @id @default(cuid())
  workspaceId        String
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name               String
  email              String
  phone              String?
  source             String    @default("Other") // Facebook Ads, Website, WhatsApp, etc.
  channel            String    @default("email") // email, sms, whatsapp
  propertyType       String?
  budget             String?
  budgetMin          Float?
  budgetMax          Float?
  locationPreference String?
  bedroomsNeeded     Int?
  timeline           String?
  notes              String?
  status             String    @default("New") // New, Active, Follow-up, Hot, Warm, Cold, Closed, Disqualified
  score              Int       @default(0)
  scoreBreakdown     String?   // Stringified JSON tracking values
  intent             String    @default("unknown") // buying, renting, investing, browsing, unknown
  urgency            String    @default("unknown") // immediate, within_month, within_3months, unknown
  qualificationStage String    @default("unqualified") // unqualified, contacted, qualifying, qualified
  aiAgentActive      Boolean   @default(true)
  aiPausedUntil      DateTime?
  humanTookOver      Boolean   @default(false)
  lastContactedAt    DateTime?
  nextFollowUpAt     DateTime?
  firstReplyAt       DateTime?
  responseTimeMs     Int?
  crmId              String?
  crmSource          String?
  externalId         String?

  // NEW FIELDS
  lastActivityAt       DateTime?
  sentimentScore       Float?
  aiAnalysisSummary    String?
  preferredContactTime String?
  timezone             String?
  propertyMatchIds     String?
  dealValue            Float?
  closeProbability     Float?
  tags                 String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  followUps        FollowUp[]
  emailEvents      EmailEvent[]
  conversations    Conversation[]
  engagementEvents EngagementEvent[]
  handoffs         HumanHandoff[]
  roiEvents        ROIEvent[]
  memoryEntries    MemoryEntry[]
  appointments     Appointment[]
  notifications    Notification[]
  whatsappMessages WhatsAppMessage[]
  aiDecisionLogs   AIDecisionLog[]

  @@index([workspaceId, status])
  @@index([workspaceId, score])
  @@index([workspaceId, aiAgentActive])
  @@index([workspaceId, email])
  @@index([workspaceId, lastActivityAt])
}
// ─── CONVERSATION (multi-channel memory) ─────────────────────────────────────

model Conversation {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  channel     String   @default("email")
  status      String   @default("active") // active, paused, closed, handed_off
  summary     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages Message[]

  @@index([leadId, channel, status])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // user, assistant, system
  content        String
  channel        String       @default("email")
  sentAt         DateTime     @default(now())
  deliveredAt    DateTime?
  readAt         DateTime?
  externalId     String?
  metadata       String?      // Stringified JSON payload

  @@index([conversationId, sentAt])
}

// ─── AI AGENT CONFIG ──────────────────────────────────────────────────────────

model AgentConfig {
  id                  String   @id @default(cuid())
  workspaceId         String   @unique
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  agentName           String   @default("AI Assistant")
  tone                String   @default("professional") // professional, friendly, casual
  language            String   @default("en")
  replyDelaySeconds   Int      @default(5)
  maxDailyMessages    Int      @default(3)
  qualifyingQuestions String?
  hotScoreThreshold   Int      @default(60)
  warmScoreThreshold  Int      @default(30)
  autoHandoffScore    Int      @default(80)
  enableEmail         Boolean  @default(true)
  enableSMS           Boolean  @default(false)
  enableWhatsApp      Boolean  @default(false)
  followUpHours24     Boolean  @default(true)
  followUpHours72     Boolean  @default(true)
  reactivateDays30    Boolean  @default(true)
  systemPromptOverride String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ─── FOLLOW-UP SEQUENCE ───────────────────────────────────────────────────────

model FollowUp {
  id             String    @id @default(cuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leadId         String
  lead           Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sequenceNumber Int
  subject        String
  body           String
  channel        String    @default("email")
  scheduledAt    DateTime?
  sentAt         DateTime?
  status         String    @default("draft") // draft, scheduled, sent, opened, replied, failed
  approved       Boolean   @default(false)
  sendAfterDays  Int       @default(0)
  aiGenerated    Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  emailEvents EmailEvent[]
}

// ─── EMAIL EVENTS ─────────────────────────────────────────────────────────────

model EmailEvent {
  id            String    @id @default(cuid())
  leadId        String
  lead          Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  followUpId    String?
  followUp      FollowUp? @relation(fields: [followUpId], references: [id])
  type          String    // opened, clicked, replied, sent, bounced, unsubscribed
  trackingToken String?   @unique
  metadata      String?   // Stringified JSON metadata payload
  createdAt     DateTime  @default(now())
}

// ─── ENGAGEMENT EVENTS (multi-signal scoring) ─────────────────────────────────

model EngagementEvent {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String   // email_opened, link_clicked, whatsapp_replied, etc.
  channel   String   @default("email")
  value     Int      @default(0)
  metadata  String?  // Stringified JSON metadata payload
  createdAt DateTime @default(now())

  @@index([leadId, type])
}

// ─── JOB QUEUE (event-driven worker system) ───────────────────────────────────

model JobQueue {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type        String    // ai_reply, follow_up, score_update, etc.
  payload     String    // Stringified JSON tracking parameters
  status      String    @default("pending") // pending, running, completed, failed, cancelled
  priority    Int       @default(5)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  runAt       DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  failedAt    DateTime?
  error       String?
  createdAt   DateTime  @default(now())

  @@index([status, priority, runAt])
  @@index([workspaceId, status])
  @@index([workspaceId, type, createdAt])
}

// ─── WEBHOOK EVENTS (inbound lead sources) ────────────────────────────────────

model WebhookEvent {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  source      String    // facebook, whatsapp, webform
  eventType   String
  payload     String    // Stringified raw incoming body content
  processed   Boolean   @default(false)
  leadId      String?
  error       String?
  receivedAt  DateTime  @default(now())

  @@index([workspaceId, processed])
}

// ─── HUMAN HANDOFF ────────────────────────────────────────────────────────────

model HumanHandoff {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leadId      String
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedTo  String?
  agent       User?     @relation(fields: [assignedTo], references: [id])
  reason      String
  aiSummary   String?
  intent      String?
  budget      String?
  objections  String?
  recommended String?
  status      String    @default("pending") // pending, notified, accepted, resolved
  notifiedAt  DateTime?
  acceptedAt  DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId, status])
}

// ─── INTEGRATIONS ─────────────────────────────────────────────────────────────

model Integration {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  provider     String    // hubspot, salesforce, facebook, whatsapp, etc.
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  config       String?   // Stringified JSON structure layout config
  status       String    @default("active") // active, error, disconnected
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([workspaceId, provider])
}

// ─── SUBSCRIPTION + STRIPE ────────────────────────────────────────────────────

model Subscription {
  id                   String    @id @default(cuid())
  workspaceId          String
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  plan                 String    @default("free") // free, starter, pro, enterprise
  status               String    @default("trialing") // trialing, active, past_due, cancelled
  startsAt             DateTime  @default(now())
  endsAt               DateTime?
  trialEndsAt          DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)

  usageLeads    Int @default(0)
  usageMessages Int @default(0)
  limitLeads    Int @default(50)
  limitMessages Int @default(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── ROI EVENTS (revenue attribution) ────────────────────────────────────────

model ROIEvent {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leadId       String
  lead         Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type         String    // viewing_booked, deal_closed, lead_reactivated
  value        Float?
  channel      String?
  aiInfluenced Boolean   @default(false)
  metadata     String?   // Stringified JSON structural tracker
  createdAt    DateTime  @default(now())

  @@index([workspaceId, type])
}

// ═══════════════════════════════════════════════════════════════════════════════
// NEW MODELS - AI Sales Agent Platform Upgrade
// ═══════════════════════════════════════════════════════════════════════════════

// ─── MEMORY ENTRY (structured per-lead memory) ────────────────────────────────

model MemoryEntry {
  id             String   @id @default(cuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leadId         String
  lead           Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  conversationId String?
  type           String    // fact, preference, objection, intent, timeline
  key            String
  value          String
  confidence     Float     @default(1.0)
  source         String    // ai_extracted, manual, system
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([leadId, type])
  @@index([workspaceId, type])
}

// ─── AI DECISION LOG (audit trail) ────────────────────────────────────────────

model AIDecisionLog {
  id             String    @id @default(cuid())
  workspaceId    String
  workspace      Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leadId         String
  lead           Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  action         String     // reply, handoff, followup, etc.
  trigger        String
  decisionType   String     // ai_generated, rule_based, hybrid
  inputContext   String?    // JSON snapshot
  outputDecision String?    // JSON snapshot
  latencyMs      Int?
  confidence     Float?
  humanReviewed  Boolean    @default(false)
  createdAt      DateTime   @default(now())

  @@index([workspaceId, createdAt])
  @@index([leadId])
}

// ─── PROPERTY LISTINGS (for future matching) ──────────────────────────────────

model Property {
  id            String   @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  externalId    String?
  title         String
  description   String?
  price         Float
  priceMin      Float?
  priceMax      Float?
  propertyType  String   // apartment, house, condo, land, commercial
  bedrooms      Int?
  bathrooms     Int?
  squareFootage Float?
  location      String
  city          String?
  state         String?
  zipCode       String?
  status        String   // available, pending, sold, rented
  images        String?  // JSON array of URLs
  features      String?  // JSON array
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointments Appointment[]

  @@index([workspaceId, status, price])
  @@index([workspaceId, propertyType])
}

// ─── APPOINTMENT / VIEWING ────────────────────────────────────────────────────

model Appointment {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leadId      String
  lead        Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  propertyId  String?
  Property    Property?  @relation(fields: [propertyId], references: [id])
  scheduledAt DateTime
  durationMin Int        @default(30)
  status      String     // scheduled, confirmed, completed, cancelled, no_show
  channel     String     // whatsapp, email, phone, in_person
  notes       String?
  aiBooked    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([workspaceId, scheduledAt])
  @@index([leadId])
}

// ─── NOTIFICATION LOG (agent alerts) ──────────────────────────────────────────

model Notification {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  leadId      String?
  lead        Lead?     @relation(fields: [leadId], references: [id])
  type        String    // hot_lead, handoff, score_alert, booking, system, lead_replied
  title       String
  message     String
  channel     String    // in_app, email, sms, whatsapp
  readAt      DateTime?
  sentAt      DateTime?
  metadata    String?   // JSON
  createdAt   DateTime  @default(now())

  @@index([userId, readAt])
  @@index([workspaceId, type, createdAt])
}

// ─── WHATSAPP MESSAGE LOG ─────────────────────────────────────────────────────

model WhatsAppMessage {
  id             String    @id @default(cuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leadId         String
  lead           Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  conversationId String?
  direction      String    // outbound, inbound
  body           String
  mediaUrl       String?
  status         String    // sent, delivered, read, failed
  twilioSid      String?   @unique
  price          Float?
  sentAt         DateTime  @default(now())
  deliveredAt    DateTime?
  readAt         DateTime?

  @@index([leadId, sentAt])
}