# Database
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# OpenAI
OPENAI_API_KEY="sk-..."

# Resend (Email)
RESEND_API_KEY="re_..."
RESEND_FROM="noreply@yourdomain.com"

# Twilio (SMS/WhatsApp)
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+1234567890"
TWILIO_WHATSAPP_NUMBER="+1234567890"

# HubSpot CRM Integration
HUBSPOT_CLIENT_ID="your-hubspot-app-client-id"
HUBSPOT_CLIENT_SECRET="your-hubspot-app-client-secret"

# App URL (used for OAuth redirects and webhooks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Vercel Cron Secret (protects /api/worker/poll from unauthorized access)
# Generate a random string: openssl rand -hex 32
# Set this in Vercel Dashboard (Environment Variables) AND in Vercel Cron Jobs config
CRON_SECRET="your-cron-secret-change-in-production"

# Stripe (Billing)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."


